#!/bin/bash

set -euo pipefail

set +u
source ~/.bashrc
set -u
conda activate "${CONDA_ENV:-clumping-factor}"

cd "${PROJECT_DIR:-$PBS_O_WORKDIR}"
mkdir -p results logs

SNAPSHOT="${SNAPSHOT:?SNAPSHOT must be set.}"
BASE_PATH="${BASE_PATH:?BASE_PATH must point to the simulation output directory.}"
MFP_FILE="${MFP_FILE:-}"
COMPUTE_MISSING_IONIZING="${COMPUTE_MISSING_IONIZING:-0}"
MFP_LOS_FILE="${MFP_LOS_FILE:-}"
ALLOW_MFP_LOS_REDSHIFT_MISMATCH="${ALLOW_MFP_LOS_REDSHIFT_MISMATCH:-0}"
MFP_STARTS_PER_RAY="${MFP_STARTS_PER_RAY:-100}"
MFP_SEED="${MFP_SEED:-0}"
GAMMA_HI_THRESHOLD="${GAMMA_HI_THRESHOLD:-0.5}"
REFRESH_IONIZING_CACHE="${REFRESH_IONIZING_CACHE:-0}"
ALLOW_LEGACY_IONIZING_TABLE="${ALLOW_LEGACY_IONIZING_TABLE:-0}"
SIGMA_HI_CM2="${SIGMA_HI_CM2:?SIGMA_HI_CM2 must be set.}"
SIMULATION_NAME="${SIMULATION_NAME:-}"
OUTPUT_DIR="${OUTPUT_DIR:-results}"
OUTPUT="${OUTPUT:-}"
CONDA_ENV="${CONDA_ENV:-clumping-factor}"
GAMMA_HI_FILE="${GAMMA_HI_FILE:-}"
TEMPERATURE_FILE="${TEMPERATURE_FILE:-}"
REDUCED_SPEED_OF_LIGHT_FRACTION="${REDUCED_SPEED_OF_LIGHT_FRACTION:-0.2}"
C_TILDE_CM_S="${C_TILDE_CM_S:-}"
PHOTON_GROUPS_CSV="${PHOTON_GROUPS_CSV:-0}"
PHOTON_GROUP_TESTS_CSV="${PHOTON_GROUP_TESTS_CSV:-}"
THRESHOLDS_CSV="${THRESHOLDS_CSV:-}"
THRESHOLD_MIN="${THRESHOLD_MIN:--1}"
THRESHOLD_MAX="${THRESHOLD_MAX:-25}"
THRESHOLD_COUNT="${THRESHOLD_COUNT:-200}"
IONIZED_DENSITY_THRESHOLDS_CSV="${IONIZED_DENSITY_THRESHOLDS_CSV:-}"
IONIZED_CUTS_CSV="${IONIZED_CUTS_CSV:-}"
IONIZED_SWEEP="${IONIZED_SWEEP:-0}"
IONIZED_CUT_MIN="${IONIZED_CUT_MIN:-0.9}"
IONIZED_CUT_MAX="${IONIZED_CUT_MAX:-0.9999}"
IONIZED_CUT_COUNT="${IONIZED_CUT_COUNT:-200}"
CHUNK_SIZE="${CHUNK_SIZE:-1000000}"
THREADS="${THREADS:-1}"
HYDROGEN_MASS_FRACTION="${HYDROGEN_MASS_FRACTION:-0.76}"
CHI_E="${CHI_E:-1.08}"
PROGRESS_INTERVAL="${PROGRESS_INTERVAL:-5}"
VERBOSE="${VERBOSE:-1}"

export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1

if [[ -z "${SIMULATION_NAME}" ]]; then
  base_trimmed="${BASE_PATH%/}"
  SIMULATION_NAME="$(basename "${base_trimmed}")"
  if [[ "${SIMULATION_NAME}" == "output" ]]; then
    SIMULATION_NAME="$(basename "$(dirname "${base_trimmed}")")"
  fi
fi

snapshot_padded="$(printf "%03d" "${SNAPSHOT}")"
if [[ -z "${OUTPUT}" ]]; then
  OUTPUT="${OUTPUT_DIR}/${SIMULATION_NAME}/gas/equation-tests/snapshot${snapshot_padded}_full_diagnostics.json"
fi
mkdir -p "$(dirname "${OUTPUT}")"

EXTRA_ARGS=()
if [[ -n "${MFP_FILE}" ]]; then
  EXTRA_ARGS+=(--mfp-file "${MFP_FILE}")
fi
if [[ "${COMPUTE_MISSING_IONIZING}" == "1" ]]; then
  EXTRA_ARGS+=(--compute-missing-ionizing --mfp-starts-per-ray "${MFP_STARTS_PER_RAY}" --mfp-seed "${MFP_SEED}" --gamma-hi-threshold "${GAMMA_HI_THRESHOLD}")
  if [[ -n "${MFP_LOS_FILE}" ]]; then
    EXTRA_ARGS+=(--mfp-los-file "${MFP_LOS_FILE}")
  fi
  if [[ "${ALLOW_MFP_LOS_REDSHIFT_MISMATCH}" == "1" ]]; then
    EXTRA_ARGS+=(--allow-mfp-los-redshift-mismatch)
  fi
fi
if [[ "${REFRESH_IONIZING_CACHE}" == "1" ]]; then
  EXTRA_ARGS+=(--refresh-ionizing-cache)
fi
if [[ "${ALLOW_LEGACY_IONIZING_TABLE}" == "1" ]]; then
  EXTRA_ARGS+=(--allow-legacy-ionizing-table)
fi
if [[ "${VERBOSE}" == "1" ]]; then
  EXTRA_ARGS+=(--verbose --progress-interval "${PROGRESS_INTERVAL}")
fi
if [[ -n "${GAMMA_HI_FILE}" ]]; then
  EXTRA_ARGS+=(--gamma-hi-file "${GAMMA_HI_FILE}")
fi
if [[ -n "${TEMPERATURE_FILE}" ]]; then
  EXTRA_ARGS+=(--temperature-file "${TEMPERATURE_FILE}")
fi
if [[ -n "${C_TILDE_CM_S}" ]]; then
  EXTRA_ARGS+=(--c-tilde-cm-s "${C_TILDE_CM_S}")
else
  EXTRA_ARGS+=(--reduced-speed-of-light-fraction "${REDUCED_SPEED_OF_LIGHT_FRACTION}")
fi
IFS=':' read -r -a photon_group_array <<< "${PHOTON_GROUPS_CSV}"
if [[ -n "${PHOTON_GROUP_TESTS_CSV}" ]]; then
  IFS=':' read -r -a photon_group_test_array <<< "${PHOTON_GROUP_TESTS_CSV}"
  EXTRA_ARGS+=(--photon-group-tests "${photon_group_test_array[@]}")
fi
if [[ -n "${THRESHOLDS_CSV}" ]]; then
  IFS=':' read -r -a threshold_array <<< "${THRESHOLDS_CSV}"
  EXTRA_ARGS+=(--thresholds "${threshold_array[@]}")
else
  EXTRA_ARGS+=(
    --threshold-min "${THRESHOLD_MIN}"
    --threshold-max "${THRESHOLD_MAX}"
    --threshold-count "${THRESHOLD_COUNT}"
  )
fi
if [[ -n "${IONIZED_CUTS_CSV}" ]]; then
  IFS=':' read -r -a ionized_cut_array <<< "${IONIZED_CUTS_CSV}"
  EXTRA_ARGS+=(--ionized-cuts "${ionized_cut_array[@]}")
elif [[ "${IONIZED_SWEEP}" == "1" ]]; then
  EXTRA_ARGS+=(
    --ionized-sweep
    --ionized-cut-min "${IONIZED_CUT_MIN}"
    --ionized-cut-max "${IONIZED_CUT_MAX}"
    --ionized-cut-count "${IONIZED_CUT_COUNT}"
  )
fi
if [[ -n "${IONIZED_DENSITY_THRESHOLDS_CSV}" ]]; then
  IFS=':' read -r -a ionized_density_threshold_array \
    <<< "${IONIZED_DENSITY_THRESHOLDS_CSV}"
  EXTRA_ARGS+=(
    --ionized-density-thresholds "${ionized_density_threshold_array[@]}"
  )
fi

echo "Started: $(date)"
echo "Host: $(hostname)"
echo "Simulation: ${SIMULATION_NAME}"
echo "Snapshot: ${SNAPSHOT}"
echo "Base path: ${BASE_PATH}"
echo "MFP file: ${MFP_FILE}"
echo "MFP LOS redshift mismatch allowed: ${ALLOW_MFP_LOS_REDSHIFT_MISMATCH}"
echo "Sigma_HI: ${SIGMA_HI_CM2} cm^2"
echo "Photon groups: ${PHOTON_GROUPS_CSV//:/ }"
if [[ -n "${PHOTON_GROUP_TESTS_CSV}" ]]; then
  echo "Photon group tests: ${PHOTON_GROUP_TESTS_CSV//:/ }"
fi
echo "Thresholds: ${THRESHOLDS_CSV//:/ }"
if [[ -z "${THRESHOLDS_CSV}" ]]; then
  echo "Threshold sweep: ${THRESHOLD_MIN} to ${THRESHOLD_MAX} (${THRESHOLD_COUNT})"
fi
echo "Ionized cuts: ${IONIZED_CUTS_CSV//:/ }"
if [[ -z "${IONIZED_CUTS_CSV}" && "${IONIZED_SWEEP}" == "1" ]]; then
  echo "Ionized sweep: ${IONIZED_CUT_MIN} to ${IONIZED_CUT_MAX} (${IONIZED_CUT_COUNT})"
elif [[ -z "${IONIZED_CUTS_CSV}" ]]; then
  echo "Ionized cuts: none"
fi
echo "Ionized density thresholds: ${IONIZED_DENSITY_THRESHOLDS_CSV//:/ }"
echo "Output: ${OUTPUT}"
echo "Worker threads: ${THREADS}"

clumping-equation-tests \
  --base-path "${BASE_PATH}" \
  --simulation-name "${SIMULATION_NAME}" \
  --snapshot "${SNAPSHOT}" \
  --sigma-hi-cm2 "${SIGMA_HI_CM2}" \
  --photon-groups "${photon_group_array[@]}" \
  --chunk-size "${CHUNK_SIZE}" \
  --workers "${THREADS}" \
  --hydrogen-mass-fraction "${HYDROGEN_MASS_FRACTION}" \
  --chi-e "${CHI_E}" \
  --output "${OUTPUT}" \
  "${EXTRA_ARGS[@]}"

echo "Finished: $(date)"
